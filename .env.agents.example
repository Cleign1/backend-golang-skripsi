# Example .env file for AI Agents Stock Management System

# =============================================================================
# DATABASE SETTINGS (REQUIRED)
# =============================================================================
# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/stock_management

# =============================================================================
# SERVER SETTINGS
# =============================================================================
# Port for the FastAPI server
PORT=8080

# Batch size for processing products (default: 500)
BATCH_SIZE=500

# Callback URL for async task results (optional)
# The prediction agent will POST results to this URL
CALLBACK_URL=http://localhost:5000/prediction-callback

# =============================================================================
# GOOGLE DRIVE INTEGRATION (OPTIONAL)
# =============================================================================
# Google Drive folder ID where prediction results will be uploaded
# Leave empty to disable Google Drive upload
GOOGLE_DRIVE_FOLDER_ID=

# Path to Google service account credentials JSON file
# Leave empty to disable Google Drive integration
GOOGLE_CREDENTIALS_PATH=

# =============================================================================
# AI/LLM SETTINGS (OPTIONAL)
# =============================================================================
# OpenAI API key for intelligent analysis
# Leave empty to use basic rule-based processing
OPENAI_API_KEY=

# LangChain API key for tracing and monitoring
# Leave empty to disable LangChain tracing
LANGCHAIN_API_KEY=

# Enable LangChain tracing (true/false)
LANGCHAIN_TRACING_V2=false

# =============================================================================
# AGENT BEHAVIOR SETTINGS
# =============================================================================
# Maximum number of retries for failed operations
AGENT_MAX_RETRIES=3

# Timeout in seconds for agent operations
AGENT_TIMEOUT=300