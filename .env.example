# Database Configuration
DATABASE_URL=your_database_url_here

# Server Configuration
BATCH_SIZE=500
PORT=8080

# Flask App Callback URL
CALLBACK_URL=your_callback_url_here

# Google Cloud Platform Configuration
GCP_BUCKET_NAME=your-gcp-bucket-name

# Note: For GCP authentication, you should either:
# 1. Set GOOGLE_APPLICATION_CREDENTIALS environment variable to point to your service account key file
# 2. Use Application Default Credentials (ADC) if running on GCP
# 3. Use gcloud auth application-default login for local development