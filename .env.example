# PostgreSQL Connection URL
DATABASE_URL=POSTGRES ADDRESS

# Server Configuration
BATCH_SIZE=500
PORT=8080

# Google AI Studio Configuration
GOOGLE_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Google drive
GOOGLE_DRIVE_FOLDER_ID=GDRIVE FOLDER ID
GOOGLE_CREDENTIALS_PATH=private_key.json

# The URL of your Flask app that will receive the final results
CALLBACK_URL=URL FOR FLASK APP